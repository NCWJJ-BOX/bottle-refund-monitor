# Required — Set these in Vercel Environment Variables
# DO NOT commit actual values to git

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=your-32-char-minimum-secret-here

# Auth credentials
AUTH_USERNAME=admin
AUTH_PASSWORD=your-secure-password-here

# Upstash Redis (from Vercel KV dashboard)
KV_REST_API_URL=https://your-upstash-redis-url
KV_REST_API_TOKEN=your-upstash-token

# KIOSK_API_KEY — shared secret between agent and server (optional)
# Generate with: openssl rand -hex 32
KIOSK_API_KEY=your-kiosk-api-key-here

# CHECK_API_KEY — secret for triggering HTTP checks via cron (optional)
# Generate with: openssl rand -hex 32
# Used by cron-job.org or similar to call /api/check/run
CHECK_API_KEY=your-check-api-key-here
